          "rawSql": "with latest_slow_run as (\n  select slow_run_started_at\n  from nginx_access_runs\n  where slow_run_started_at between $__fromTime and $__toTime\n  order by slow_run_started_at desc\n  limit 1\n)\nselect\n  uri\n  , method\n  , count as \"合計\"\n  , c_2xx as \"2xx\"\n  , c_3xx as \"3xx\"\n  , c_4xx as \"4xx\"\n  , c_5xx as \"5xx\"\n  , sum as \"合計時間\"\n  , min as \"最短時間\"\n  , max as \"最長時間\"\n  , avg as \"平均時間\"\n  , p90 as \"p90時間\"\nfrom nginx_access_runs\nwhere slow_run_started_at = (select slow_run_started_at from latest_slow_run)\norder by sum desc\n;",
          "refId": "A"
        }
