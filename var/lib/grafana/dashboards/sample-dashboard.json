          "rawSql": "with latest_slow_run as (\n  select log_started_at\n  from slow_runs\n  where log_started_at between $__fromTime and $__toTime\n  order by log_started_at desc\n  limit 1\n)\nselect\n  example_query as \"クエリ\"\n  , query_count as \"クエリ数\"\n  , qtime_sum as \"合計時間\"\n  , qtime_avg as \"平均時間\"\n  , qtime_pct95 as \"p95時間\"\n  , rows_exam_sum as \"合計走査行数\"\n  , rows_exam_avg as \"平均走査行数\"\n  , rows_exam_pct95 as \"p95走査行数\"\nfrom slow_queries\nwhere\n  log_started_at = (select log_started_at from latest_slow_run)\norder by qtime_sum desc\n;",
