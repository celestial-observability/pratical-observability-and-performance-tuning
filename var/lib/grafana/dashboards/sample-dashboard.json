          "pluginVersion": "4.14.0",
          "queryType": "table",
          "rawSql": "with latest_slow_run as (\n  select log_started_at, log_ended_at\n  from slow_runs\n  where log_started_at between $__fromTime and $__toTime\n  order by log_started_at desc\n  limit 1\n), root_traces as (\n  -- TraceIdでグルーピング\n  -- 代表のSpanNameを抽出\n  select\n    TraceId as trace_id\n    , SpanAttributes['http.method'] as http_method\n    , SpanName as span_name\n  from otel_traces\n  where Timestamp between (select log_started_at from latest_slow_run) and (select log_ended_at from latest_slow_run)\n    and ParentSpanId = ''\n), traces as (\n  -- span_name: 代表スパン名\n  select\n    trace_id\n    , http_method\n    , min(span_name) as span_name\n    , count() as span_count\n    , sum(Duration) as sum_duration\n    , (select count() from otel_traces ot where ot.TraceId = trace_id and ot.SpanName like 'sql%') as sql_span_count\n  from otel_traces\n  join root_traces on trace_id = TraceId\n  group by trace_id, http_method\n)\n-- span_nameで更にグルーピング\n-- TraceIdは代表TraceId\n-- TraceIdという列名にすると、トレースへのリンクになる\n-- 平均span数が多いほど、N+1問題が起きている\nselect\n  span_name as \"span名\"\n  , http_method as \"method\"\n  , argMax(trace_id, sum_duration) as \"TraceId\"\n  , avg(span_count) as \"平均span数\"\n  , avg(sql_span_count) as \"平均sql_span数\"\n  , sum(span_count) as \"合計span数\"\n  , sum(sql_span_count) as \"合計sql_span数\"\n  , max(span_count) as \"最大span数\"\n  , max(sql_span_count) as \"最大sql_span数\"\n  , min(span_count) as \"最小span数\"\n  , min(sql_span_count) as \"最小sql_span数\"\nfrom traces\ngroup by span_name, http_method\norder by \"合計span数\" desc\n;",
          "refId": "A"
        }
      ],
      "title": "時間範囲内の最新ベンチのspan数(for N+1問題)",
      "type": "table"
    }
